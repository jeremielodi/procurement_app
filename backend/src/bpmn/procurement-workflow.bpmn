<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_ProcurementProcess" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.46.1" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">
  <bpmn:process id="ProcurementProcess" name="Electronic Procurement Management Process" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Requester" name="Requester">
        <bpmn:flowNodeRef>StartEvent_NewRequisition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_BudgetAdjustment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_POCancelled</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ServiceAcceptance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SANDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_SANRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_InvoiceDispute</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Finance" name="Finance">
        <bpmn:flowNodeRef>Task_CheckBudget</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_BudgetDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ValidationN2_Finance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_EnterInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProcessInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InvoiceDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ProcessPayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Completed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Management" name="Management">
        <bpmn:flowNodeRef>Gateway_AmountDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ValidationN1_Manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_POApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_POApprovalDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ApprovalDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ValidationN3_DG</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Procurement" name="Procurement">
        <bpmn:flowNodeRef>Activity_DetermineType</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClassifyProcurement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MethodDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_DirectPurchase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RequestQuotations</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RFPProcess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_SoleSource</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AnalyzeOffers</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_CreatePO</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendPO</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_SupplierConfirmation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Logistics" name="Logistics">
        <bpmn:flowNodeRef>Activity_GoodsReceipt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_GRNDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_GRNDispute</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_NewRequisition" name="Requisition Submitted">
      <bpmn:outgoing>Flow_Start_CheckBudget</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckBudget" name="Check Budget Availability" camunda:type="external" camunda:topic="check_budget">
      <bpmn:incoming>Flow_Start_CheckBudget</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckBudget_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_BudgetDecision" name="Budget Available?">
      <bpmn:incoming>Flow_CheckBudget_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Budget_OK</bpmn:outgoing>
      <bpmn:outgoing>Flow_Budget_KO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_BudgetAdjustment" name="Request Budget Adjustment" camunda:assignee="${requesterId}" camunda:candidateGroups="requester">
      <bpmn:incoming>Flow_Budget_KO</bpmn:incoming>
      <bpmn:outgoing>Flow_BudgetAdjustment_Reject</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_Rejected" name="Process Rejected">
      <bpmn:incoming>Flow_BudgetAdjustment_Reject</bpmn:incoming>
      <bpmn:incoming>Flow_Approval_Rejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_AmountDecision" name="Approval Level?">
      <bpmn:incoming>Flow_Budget_OK</bpmn:incoming>
      <bpmn:outgoing>Flow_Amount_N1</bpmn:outgoing>
      <bpmn:outgoing>Flow_Amount_N2</bpmn:outgoing>
      <bpmn:outgoing>Flow_Amount_N3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_ValidationN1_Manager" name="Manager Approval (N1)" camunda:assignee="${approver}" camunda:candidateGroups="manager">
      <bpmn:incoming>Flow_Amount_N1</bpmn:incoming>
      <bpmn:outgoing>Flow_N1_ApprovalGateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_ValidationN2_Finance" name="Finance Approval (N2)" camunda:assignee="${approver}" camunda:candidateGroups="finance">
      <bpmn:incoming>Flow_Amount_N2</bpmn:incoming>
      <bpmn:outgoing>Flow_N2_ApprovalGateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_ValidationN3_DG" name="DG Approval (N3)" camunda:assignee="${approver}" camunda:candidateGroups="dg">
      <bpmn:incoming>Flow_Amount_N3</bpmn:incoming>
      <bpmn:outgoing>Flow_N3_ApprovalGateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ApprovalDecision" name="Approved?">
      <bpmn:incoming>Flow_N1_ApprovalGateway</bpmn:incoming>
      <bpmn:incoming>Flow_N2_ApprovalGateway</bpmn:incoming>
      <bpmn:incoming>Flow_N3_ApprovalGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved_DetermineType</bpmn:outgoing>
      <bpmn:outgoing>Flow_Approval_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_DetermineType" name="Determine Procurement Type" camunda:assignee="${procurementOfficer}" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_Approved_DetermineType</bpmn:incoming>
      <bpmn:outgoing>Flow_DetermineType_Classify</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ClassifyProcurement" name="Classify Procurement Method" camunda:type="external" camunda:topic="classify_procurement">
      <bpmn:incoming>Flow_DetermineType_Classify</bpmn:incoming>
      <bpmn:outgoing>Flow_Classify_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_MethodDecision" name="Select Method">
      <bpmn:incoming>Flow_Classify_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Method_DirectPurchase</bpmn:outgoing>
      <bpmn:outgoing>Flow_Method_Quotations</bpmn:outgoing>
      <bpmn:outgoing>Flow_Method_RFP</bpmn:outgoing>
      <bpmn:outgoing>Flow_Method_SoleSource</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_DirectPurchase" name="Direct Purchase" camunda:assignee="${procurementOfficer}" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_Method_DirectPurchase</bpmn:incoming>
      <bpmn:outgoing>Flow_DirectPurchase_CreatePO</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_RequestQuotations" name="Request Multiple Quotations" camunda:assignee="${procurementOfficer}" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_Method_Quotations</bpmn:incoming>
      <bpmn:outgoing>Flow_Quotations_Analyze</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_RFPProcess" name="Call for Tenders / RFP" camunda:assignee="${procurementOfficer}" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_Method_RFP</bpmn:incoming>
      <bpmn:outgoing>Flow_RFP_Analyze</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_SoleSource" name="Sole Source Justification" camunda:assignee="${procurementOfficer}" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_Method_SoleSource</bpmn:incoming>
      <bpmn:outgoing>Flow_SoleSource_CreatePO</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_AnalyzeOffers" name="Analyze Offers" camunda:type="external" camunda:topic="analyze_offers">
      <bpmn:incoming>Flow_Quotations_Analyze</bpmn:incoming>
      <bpmn:incoming>Flow_RFP_Analyze</bpmn:incoming>
      <bpmn:outgoing>Flow_Analyze_CreatePO</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_CreatePO" name="Create Purchase Order" camunda:assignee="${procurementOfficer}" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_DirectPurchase_CreatePO</bpmn:incoming>
      <bpmn:incoming>Flow_Analyze_CreatePO</bpmn:incoming>
      <bpmn:incoming>Flow_SoleSource_CreatePO</bpmn:incoming>
      <bpmn:outgoing>Flow_CreatePO_POApproval</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_POApproval" name="Approve Purchase Order" camunda:assignee="${manager}" camunda:candidateGroups="management">
      <bpmn:incoming>Flow_CreatePO_POApproval</bpmn:incoming>
      <bpmn:outgoing>Flow_POApproval_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_POApprovalDecision" name="PO Approved?">
      <bpmn:incoming>Flow_POApproval_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_POApproved_SendPO</bpmn:outgoing>
      <bpmn:outgoing>Flow_PORejected_Cancel</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_POCancelled" name="PO Cancelled">
      <bpmn:incoming>Flow_PORejected_Cancel</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_SendPO" name="Send PO to Supplier" camunda:type="external" camunda:topic="send_po_notification">
      <bpmn:incoming>Flow_POApproved_SendPO</bpmn:incoming>
      <bpmn:outgoing>Flow_SendPO_SupplierConfirmation</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_SupplierConfirmation" name="Supplier Order Confirmation" camunda:assignee="${procurementOfficer}" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_SendPO_SupplierConfirmation</bpmn:incoming>
      <bpmn:outgoing>Flow_SupplierConfirmation_GRN</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_GoodsReceipt" name="Goods Receipt Note (GRN)" camunda:assignee="${storeKeeper}" camunda:candidateGroups="logistic">
      <bpmn:incoming>Flow_SupplierConfirmation_GRN</bpmn:incoming>
      <bpmn:outgoing>Flow_GRN_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_GRNDecision" name="GRN Compliant?">
      <bpmn:incoming>Flow_GRN_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_GRN_OK</bpmn:outgoing>
      <bpmn:outgoing>Flow_GRN_Dispute</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_GRNDispute" name="GRN Dispute / Return">
      <bpmn:incoming>Flow_GRN_Dispute</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_ServiceAcceptance" name="Service Acceptance Note (SAN)" camunda:assignee="${requesterId}" camunda:candidateGroups="requester">
      <bpmn:incoming>Flow_GRN_OK</bpmn:incoming>
      <bpmn:outgoing>Flow_SAN_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_SANDecision" name="Service Accepted?">
      <bpmn:incoming>Flow_SAN_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_SAN_OK</bpmn:outgoing>
      <bpmn:outgoing>Flow_SAN_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_SANRejected" name="Service Rejected">
      <bpmn:incoming>Flow_SAN_Rejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_EnterInvoice" name="Enter Supplier Invoice" camunda:assignee="${financeOfficer}" camunda:candidateGroups="finance">
      <bpmn:incoming>Flow_SAN_OK</bpmn:incoming>
      <bpmn:outgoing>Flow_EnterInvoice_ProcessInvoice</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ProcessInvoice" name="3-Way Matching (PO + GRN + Invoice)" camunda:type="external" camunda:topic="process_invoice">
      <bpmn:incoming>Flow_EnterInvoice_ProcessInvoice</bpmn:incoming>
      <bpmn:outgoing>Flow_Invoice_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_InvoiceDecision" name="Invoice Valid?">
      <bpmn:incoming>Flow_Invoice_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Invoice_OK</bpmn:outgoing>
      <bpmn:outgoing>Flow_Invoice_Dispute</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_InvoiceDispute" name="Invoice Blocked / Dispute">
      <bpmn:incoming>Flow_Invoice_Dispute</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_ProcessPayment" name="Process Payment" camunda:assignee="${financeOfficer}" camunda:candidateGroups="finance">
      <bpmn:incoming>Flow_Invoice_OK</bpmn:incoming>
      <bpmn:outgoing>Flow_Payment_Complete</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_Completed" name="Process Completed">
      <bpmn:incoming>Flow_Payment_Complete</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_CheckBudget" sourceRef="StartEvent_NewRequisition" targetRef="Task_CheckBudget" />
    <bpmn:sequenceFlow id="Flow_CheckBudget_Gateway" sourceRef="Task_CheckBudget" targetRef="Gateway_BudgetDecision" />
    <bpmn:sequenceFlow id="Flow_Budget_OK" sourceRef="Gateway_BudgetDecision" targetRef="Gateway_AmountDecision">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${budgetAvailable == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Budget_KO" sourceRef="Gateway_BudgetDecision" targetRef="Activity_BudgetAdjustment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${budgetAvailable == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_BudgetAdjustment_Reject" sourceRef="Activity_BudgetAdjustment" targetRef="Event_Rejected" />
    <bpmn:sequenceFlow id="Flow_Amount_N1" sourceRef="Gateway_AmountDecision" targetRef="Activity_ValidationN1_Manager">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${estimatedAmount &lt; 25000}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Amount_N2" sourceRef="Gateway_AmountDecision" targetRef="Activity_ValidationN2_Finance">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${estimatedAmount &gt;= 25000 &amp;&amp; estimatedAmount &lt; 100000}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Amount_N3" sourceRef="Gateway_AmountDecision" targetRef="Activity_ValidationN3_DG">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${estimatedAmount &gt;= 100000}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_N1_ApprovalGateway" sourceRef="Activity_ValidationN1_Manager" targetRef="Gateway_ApprovalDecision" />
    <bpmn:sequenceFlow id="Flow_N2_ApprovalGateway" sourceRef="Activity_ValidationN2_Finance" targetRef="Gateway_ApprovalDecision" />
    <bpmn:sequenceFlow id="Flow_N3_ApprovalGateway" sourceRef="Activity_ValidationN3_DG" targetRef="Gateway_ApprovalDecision" />
    <bpmn:sequenceFlow id="Flow_Approved_DetermineType" sourceRef="Gateway_ApprovalDecision" targetRef="Activity_DetermineType">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Approval_Rejected" sourceRef="Gateway_ApprovalDecision" targetRef="Event_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_DetermineType_Classify" sourceRef="Activity_DetermineType" targetRef="Task_ClassifyProcurement" />
    <bpmn:sequenceFlow id="Flow_Classify_Gateway" sourceRef="Task_ClassifyProcurement" targetRef="Gateway_MethodDecision" />
    <bpmn:sequenceFlow id="Flow_Method_DirectPurchase" sourceRef="Gateway_MethodDecision" targetRef="Activity_DirectPurchase">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${procurementMethod == "DIRECT_PURCHASE"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Method_Quotations" sourceRef="Gateway_MethodDecision" targetRef="Activity_RequestQuotations">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${procurementMethod == "MULTIPLE_QUOTATIONS"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Method_RFP" sourceRef="Gateway_MethodDecision" targetRef="Activity_RFPProcess">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${procurementMethod == "RFP"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Method_SoleSource" sourceRef="Gateway_MethodDecision" targetRef="Activity_SoleSource">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${procurementMethod == "SOLE_SOURCE"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_DirectPurchase_CreatePO" sourceRef="Activity_DirectPurchase" targetRef="Activity_CreatePO" />
    <bpmn:sequenceFlow id="Flow_Quotations_Analyze" sourceRef="Activity_RequestQuotations" targetRef="Task_AnalyzeOffers" />
    <bpmn:sequenceFlow id="Flow_RFP_Analyze" sourceRef="Activity_RFPProcess" targetRef="Task_AnalyzeOffers" />
    <bpmn:sequenceFlow id="Flow_Analyze_CreatePO" sourceRef="Task_AnalyzeOffers" targetRef="Activity_CreatePO" />
    <bpmn:sequenceFlow id="Flow_SoleSource_CreatePO" sourceRef="Activity_SoleSource" targetRef="Activity_CreatePO" />
    <bpmn:sequenceFlow id="Flow_CreatePO_POApproval" sourceRef="Activity_CreatePO" targetRef="Activity_POApproval" />
    <bpmn:sequenceFlow id="Flow_POApproval_Gateway" sourceRef="Activity_POApproval" targetRef="Gateway_POApprovalDecision" />
    <bpmn:sequenceFlow id="Flow_POApproved_SendPO" sourceRef="Gateway_POApprovalDecision" targetRef="Task_SendPO">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${poApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PORejected_Cancel" sourceRef="Gateway_POApprovalDecision" targetRef="Event_POCancelled">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${poApproved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_SendPO_SupplierConfirmation" sourceRef="Task_SendPO" targetRef="Activity_SupplierConfirmation" />
    <bpmn:sequenceFlow id="Flow_SupplierConfirmation_GRN" sourceRef="Activity_SupplierConfirmation" targetRef="Activity_GoodsReceipt" />
    <bpmn:sequenceFlow id="Flow_GRN_Gateway" sourceRef="Activity_GoodsReceipt" targetRef="Gateway_GRNDecision" />
    <bpmn:sequenceFlow id="Flow_GRN_OK" sourceRef="Gateway_GRNDecision" targetRef="Activity_ServiceAcceptance">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${grnCompliant == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GRN_Dispute" sourceRef="Gateway_GRNDecision" targetRef="Event_GRNDispute">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${grnCompliant == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_SAN_Gateway" sourceRef="Activity_ServiceAcceptance" targetRef="Gateway_SANDecision" />
    <bpmn:sequenceFlow id="Flow_SAN_OK" sourceRef="Gateway_SANDecision" targetRef="Activity_EnterInvoice">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${serviceAccepted == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_SAN_Rejected" sourceRef="Gateway_SANDecision" targetRef="Event_SANRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${serviceAccepted == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_EnterInvoice_ProcessInvoice" sourceRef="Activity_EnterInvoice" targetRef="Task_ProcessInvoice" />
    <bpmn:sequenceFlow id="Flow_Invoice_Gateway" sourceRef="Task_ProcessInvoice" targetRef="Gateway_InvoiceDecision" />
    <bpmn:sequenceFlow id="Flow_Invoice_OK" sourceRef="Gateway_InvoiceDecision" targetRef="Activity_ProcessPayment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${invoiceValid == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Invoice_Dispute" sourceRef="Gateway_InvoiceDecision" targetRef="Event_InvoiceDispute">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${invoiceValid == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Payment_Complete" sourceRef="Activity_ProcessPayment" targetRef="Event_Completed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_ProcurementProcess">
    <bpmndi:BPMNPlane id="BPMNPlane_ProcurementProcess" bpmnElement="ProcurementProcess">
      <bpmndi:BPMNShape id="Lane_Logistics_di" bpmnElement="Lane_Logistics" isHorizontal="true">
        <dc:Bounds x="80" y="1100" width="4200" height="180" />
